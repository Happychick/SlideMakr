# SlideMakr Environment Variables

# Gemini API key (from https://aistudio.google.com/app/apikey)
GOOGLE_API_KEY=your_gemini_api_key_here

# Google Service Account (for Slides/Drive API)
# Option 1: File path (local development)
SERVICE_ACCOUNT_PATH=/path/to/service-account.json
# Option 2: JSON string (Cloud Run / Replit)
# SERVICE_ACCOUNT_JSON={"type": "service_account", ...}

# Google Cloud Project (for Firestore)
GOOGLE_CLOUD_PROJECT=slidemakr

# Optional: Slide template ID (for template-based presentations)
# SLIDE_TEMPLATE_ID=your_template_id

# Google OAuth SSO (for user login + Drive access)
# Create at: Google Cloud Console > APIs & Services > Credentials > OAuth 2.0 Client ID
# GOOGLE_OAUTH_CLIENT_ID=your_client_id.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=your_client_secret

# Session secret key (change in production!)
# SESSION_SECRET_KEY=your-random-secret-key-here
